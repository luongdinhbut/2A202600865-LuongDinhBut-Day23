# LLM API key (required — pick one)
# FIREWORKS_API_KEY=fw_...
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model
# LLM_MODEL=accounts/fireworks/models/deepseek-v4-pro
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# FIREWORKS_TOP_K=40
# FIREWORKS_MAX_TOKENS=4096

# Optional: real HITL interrupts (default: mock approval)
# LANGGRAPH_INTERRUPT=true

# Optional: persistence backend
CHECKPOINTER=memory
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langgraph_lab

LOG_LEVEL=INFO
